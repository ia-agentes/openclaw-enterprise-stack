OPENCLAW_IMAGE={{ image }}
OPENCLAW_TZ={{ timezone }}
OPENCLAW_GATEWAY_PORT={{ gateway_port }}
OPENCLAW_BRIDGE_PORT={{ bridge_port }}
OPENCLAW_MSTEAMS_PORT={{ msteams_port }}
OPENCLAW_GATEWAY_BIND=lan

# Generated once per instance and preserved by scripts/generate.py.
OPENCLAW_GATEWAY_TOKEN={{ gateway_token }}

# Optional outbound OpenTelemetry endpoints.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=openclaw-{{ name }}
