{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "trustedProxies": [
      "{{ trusted_proxy_ip }}"
    ],
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": [
        "https://{{ domain }}",
        "http://127.0.0.1:{{ port }}",
        "http://localhost:{{ port }}"
      ]
    }
  }
}
