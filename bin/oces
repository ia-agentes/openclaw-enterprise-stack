#!/usr/bin/env bash

SCRIPT="$(readlink -f "$0")"
ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

case "$1" in

deploy)
    bash "$ROOT/scripts/deploy.sh"
;;

update)
    echo "Comando ainda não implementado neste repositório: update" >&2
    exit 2
;;

backup)
    echo "Comando ainda não implementado neste repositório: backup" >&2
    exit 2
;;

restore)
    echo "Comando ainda não implementado neste repositório: restore" >&2
    exit 2
;;

restart)
    docker compose -f "$ROOT/proxy/docker-compose.yml" up -d
;;

status)
    docker ps --filter "name=oces-" --format "table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}"
;;

logs)
    docker logs -f oces-traefik
;;

health)
    bash "$ROOT/scripts/doctor.sh"
;;

doctor)
    bash "$ROOT/scripts/doctor.sh"
;;

generate)
    python3 "$ROOT/scripts/generate.py"
;;

devices)
    shift
    bash "$ROOT/scripts/devices.sh" "$@"
;;

*)
echo

echo "OpenClaw Enterprise Stack"

echo

echo "Comandos:"

echo " oces generate"

echo " oces deploy"

echo " oces update"

echo " oces backup"

echo " oces restore"

echo " oces restart"

echo " oces status"

echo " oces logs"

echo " oces health"

echo " oces devices list"

echo " oces devices approve [--yes]"

;;

esac
