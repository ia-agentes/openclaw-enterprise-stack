#!/usr/bin/env bash

SCRIPT="$(readlink -f "$0")"
ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

case "$1" in

deploy)
    bash "$ROOT/scripts/deploy.sh"
;;

update)
    echo "Comando ainda não implementado neste repositório: update" >&2
    exit 2
;;

backup)
    echo "Comando ainda não implementado neste repositório: backup" >&2
    exit 2
;;

restore)
    echo "Comando ainda não implementado neste repositório: restore" >&2
    exit 2
;;

restart)
    docker compose -f "$ROOT/proxy/docker-compose.yml" up -d
;;

dashboard)
    if [ ! -f "$ROOT/admin/.env" ]; then
        echo "Arquivo admin/.env não encontrado. Copie admin/.env.example e configure OCES_ADMIN_TOKEN." >&2
        exit 1
    fi
    docker compose \
        -f "$ROOT/admin/docker-compose.yml" \
        --env-file "$ROOT/admin/.env" \
        up -d --build
;;

status)
    shift
    python3 "$ROOT/scripts/status.py" "$@"
;;

logs)
    docker logs -f oces-traefik
;;

health)
    bash "$ROOT/scripts/doctor.sh"
;;

doctor)
    bash "$ROOT/scripts/doctor.sh"
;;

generate)
    python3 "$ROOT/scripts/generate.py"
;;

devices)
    shift
    bash "$ROOT/scripts/devices.sh" "$@"
;;

*)
echo

echo "OpenClaw Enterprise Stack"

echo

echo "Comandos:"

echo " oces generate"

echo " oces deploy"

echo " oces update"

echo " oces backup"

echo " oces restore"

echo " oces restart"

echo " oces dashboard"

echo " oces status"

echo " oces status --json"

echo " oces logs"

echo " oces health"

echo " oces devices list"

echo " oces devices approve [--yes]"

;;

esac
